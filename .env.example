# رابط ASP.NET Core API. لا تضع رابط Swagger؛ المطلوب رابط /api فقط.
NEXT_PUBLIC_API_URL=https://lmslearning.runasp.net/api

# رابط الموقع النهائي بعد النشر لاستخدام Canonical وOpen Graph وSitemap.
# مثال: https://elmohager.com
NEXT_PUBLIC_SITE_URL=https://elmohager.vercel.app

# رقم واتساب بصيغة دولية بدون +
NEXT_PUBLIC_WHATSAPP_NUMBER=201110037311

# Google Analytics 4 - مثال G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# كود التحقق من Google Search Console من نوع HTML Tag
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# PayPal JavaScript SDK Client ID
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_CURRENCY=USD
